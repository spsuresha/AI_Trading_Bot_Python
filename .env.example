# Copy this file to .env and fill in your credentials
# Never commit your .env file to version control

# ── Exchange API ──────────────────────────────────────────────
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here

# ── Telegram Alerts ───────────────────────────────────────────
# 1. Create a bot via @BotFather and copy the token below.
# 2. Start a chat with your bot, then run:
#    python -c "from monitoring.telegram_notifier import TelegramNotifier; TelegramNotifier().get_chat_id()"
#    to find your chat_id.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=-1001234567890
# Set to "false" to disable all Telegram alerts
TELEGRAM_ENABLED=true
